generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                   @id @default(cuid())
  name               String
  email              String                   @unique
  password           String?
  profileImage       String?                  @map("profile_image")
  provider           AuthProvider[]           @default([])
  isVerified         Boolean                  @default(false) @map("is_verified")
  createdAt          DateTime                 @default(now()) @map("created_at")
  childProfile       ChildProfile?
  emailVerifications EmailVerificationToken[]
  passwordResets     PasswordResetToken[]
  subscriptions      UserSubscription[]
  payments           Payment[]

  @@map("users")
}

model ChildProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique @map("user_id")
  name               String
  ageGroup           String              @map("age_group")
  favoriteColor      String              @map("favorite_color")
  favoriteCharacter  String              @map("favorite_character")
  createdAt          DateTime            @default(now()) @map("created_at")
  childBadges        ChildBadge[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameProgress       GameProgress[]
  lessonProgress     LessonProgress[]
  progressRecords    ProgressRecord[]
  quizAttempts       QuizAttempt[]
  rewardTransactions RewardTransaction[]
  rewardWallet       RewardWallet?
  storyProgress      StoryProgress[]

  @@map("child_profiles")
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  email      String
  tokenHash  String    @map("token_hash")
  codeHash   String    @map("code_hash")
  verifiedAt DateTime? @map("verified_at")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  userId     String?   @map("user_id")
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @map("token_hash")
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  userId    String?   @map("user_id")
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model SubscriptionPlan {
  id            String                @id @default(cuid())
  name          String
  description   String?
  price         Int
  durationDays  Int
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  features      SubscriptionFeature[]
  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id        String                @id @default(cuid())
  userId    String                @map("user_id")
  planId    String                @map("plan_id")
  status    SubscriptionStatus    @default(ACTIVE)
  startDate DateTime              @map("start_date")
  endDate   DateTime              @map("end_date")
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")
  features  SubscriptionFeature[]
  plan      SubscriptionPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@map("user_subscriptions")
}

model SubscriptionFeature {
  id             String            @id @default(cuid())
  planId         String            @map("plan_id")
  subscriptionId String?           @map("subscription_id")
  featureKey     String            @map("feature_key")
  featureValue   String            @map("feature_value")
  createdAt      DateTime          @default(now()) @map("created_at")
  plan           SubscriptionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscription   UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_features")
}

model Language {
  id        String          @id @default(cuid())
  code      String          @unique
  name      String
  native    String?
  flag      String?
  isActive  Boolean         @default(true) @map("is_active")
  sortOrder Int             @default(0) @map("sort_order")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  games     Game[]
  levels    LanguageLevel[]
  lessons   Lesson[]
  quizzes   Quiz[]
  stories   Story[]

  @@map("languages")
}

model Level {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  description String?
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  games       Game[]
  languages   LanguageLevel[]
  lessons     Lesson[]
  quizzes     Quiz[]

  @@map("levels")
}

model LanguageLevel {
  id         String   @id @default(cuid())
  languageId String   @map("language_id")
  levelId    String   @map("level_id")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  level      Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([languageId, levelId])
  @@map("language_levels")
}

model Story {
  id            String          @id @default(cuid())
  slug          String          @unique
  title         String
  description   String?
  content       String
  pages         Json?
  author        String?
  category      String?
  ageGroup      String?         @map("age_group")
  tags          String[]        @default([])
  thumbnail     String?
  coverEmoji    String?         @map("cover_emoji")
  coverGradient String?         @map("cover_gradient")
  readingTime   Int?            @map("reading_time")
  duration      String?
  isPremium     Boolean         @default(false) @map("is_premium")
  audioUrl      String?         @map("audio_url")
  starsReward   Int             @default(0) @map("stars_reward")
  isPublished   Boolean         @default(true) @map("is_published")
  sortOrder     Int             @default(0) @map("sort_order")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  languageId    String?         @map("language_id")
  quizzes       Quiz[]
  language      Language?       @relation(fields: [languageId], references: [id])
  progress      StoryProgress[]

  @@index([category])
  @@index([languageId])
  @@map("stories")
}

model StoryProgress {
  id                 String       @id @default(cuid())
  childProfileId     String       @map("child_profile_id")
  storyId            String       @map("story_id")
  progressPercentage Int          @default(0) @map("progress_percentage")
  lastReadPosition   Int?         @map("last_read_position")
  isCompleted        Boolean      @default(false) @map("is_completed")
  completedAt        DateTime?    @map("completed_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  childProfile       ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  story              Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([childProfileId, storyId])
  @@map("story_progress")
}

model Lesson {
  id          String           @id @default(cuid())
  lessonCode  String?          @unique @map("lesson_code")
  slug        String           @unique
  title       String
  description String?
  intro       String?
  emoji       String?
  color       String?
  category    String?
  tags        String[]         @default([])
  status      String           @default("draft")
  isPremium   Boolean          @default(false) @map("is_premium")
  isPublished Boolean          @default(true) @map("is_published")
  sortOrder   Int              @default(0) @map("sort_order")
  archivedAt  DateTime?        @map("archived_at")
  publishedAt DateTime?        @map("published_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  languageId  String           @map("language_id")
  levelId     String           @map("level_id")
  cards       LessonCard[]
  progress    LessonProgress[]
  language    Language         @relation(fields: [languageId], references: [id], onDelete: Cascade)
  level       Level            @relation(fields: [levelId], references: [id], onDelete: Cascade)
  quizzes     Quiz[]
  versions    LessonVersion[]

  @@index([languageId, levelId])
  @@index([status])
  @@index([lessonCode])
  @@map("lessons")
}

model LessonCard {
  id        String   @id @default(cuid())
  lessonId  String   @map("lesson_id")
  word      String
  translit  String?
  meaning   String?
  emoji     String?
  imageUrl  String?  @map("image_url")
  audioUrl  String?  @map("audio_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_cards")
}

model LessonProgress {
  id                 String       @id @default(cuid())
  childProfileId     String       @map("child_profile_id")
  lessonId           String       @map("lesson_id")
  progressPercentage Int          @default(0) @map("progress_percentage")
  isCompleted        Boolean      @default(false) @map("is_completed")
  completedAt        DateTime?    @map("completed_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  childProfile       ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  lesson             Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([childProfileId, lessonId])
  @@map("lesson_progress")
}

model Quiz {
  id          String         @id @default(cuid())
  title       String
  description String?
  isPremium   Boolean        @default(false) @map("is_premium")
  isPublished Boolean        @default(true) @map("is_published")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  languageId  String?        @map("language_id")
  levelId     String?        @map("level_id")
  lessonId    String?        @map("lesson_id")
  storyId     String?        @map("story_id")
  attempts    QuizAttempt[]
  questions   QuizQuestion[]
  language    Language?      @relation(fields: [languageId], references: [id])
  lesson      Lesson?        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  level       Level?         @relation(fields: [levelId], references: [id])
  story       Story?         @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([storyId])
  @@map("quizzes")
}

model QuizQuestion {
  id          String   @id @default(cuid())
  quizId      String   @map("quiz_id")
  type        String   @default("mcq")
  question    String
  emoji       String?
  options     Json?
  answer      String
  hint        String?
  explanation String?
  points      Int      @default(1)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id             String       @id @default(cuid())
  childProfileId String       @map("child_profile_id")
  quizId         String       @map("quiz_id")
  score          Int          @default(0)
  totalPoints    Int          @default(0) @map("total_points")
  starsEarned    Int          @default(0) @map("stars_earned")
  answers        Json?
  isCompleted    Boolean      @default(true) @map("is_completed")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  quiz           Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([childProfileId])
  @@index([quizId])
  @@map("quiz_attempts")
}

model Game {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  description String?
  category    String?
  icon        String?
  color       String?
  starsReward Int            @default(0) @map("stars_reward")
  isPremium   Boolean        @default(false) @map("is_premium")
  isActive    Boolean        @default(true) @map("is_active")
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  languageId  String?        @map("language_id")
  levelId     String?        @map("level_id")
  progress    GameProgress[]
  language    Language?      @relation(fields: [languageId], references: [id])
  level       Level?         @relation(fields: [levelId], references: [id])

  @@index([languageId])
  @@index([levelId])
  @@map("games")
}

model GameProgress {
  id             String       @id @default(cuid())
  childProfileId String       @map("child_profile_id")
  gameId         String       @map("game_id")
  score          Int          @default(0)
  highScore      Int          @default(0) @map("high_score")
  attempts       Int          @default(0)
  isCompleted    Boolean      @default(false) @map("is_completed")
  lastPlayedAt   DateTime?    @map("last_played_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  game           Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([childProfileId, gameId])
  @@map("game_progress")
}

model ProgressRecord {
  id                 String              @id @default(cuid())
  childProfileId     String              @map("child_profile_id")
  contentType        ProgressContentType @map("content_type")
  contentId          String              @map("content_id")
  progressPercentage Int                 @default(0) @map("progress_percentage")
  isCompleted        Boolean             @default(false) @map("is_completed")
  metadata           Json?
  completedAt        DateTime?           @map("completed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  childProfile       ChildProfile        @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@unique([childProfileId, contentType, contentId])
  @@map("progress_records")
}

model RewardWallet {
  id             String       @id @default(cuid())
  childProfileId String       @unique @map("child_profile_id")
  stars          Int          @default(0)
  coins          Int          @default(0)
  xp             Int          @default(0)
  level          Int          @default(1)
  streak         Int          @default(0)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@map("reward_wallets")
}

model Badge {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  description String?
  imageUrl    String?      @map("image_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  children    ChildBadge[]

  @@map("badges")
}

model ChildBadge {
  id             String       @id @default(cuid())
  childProfileId String       @map("child_profile_id")
  badgeId        String       @map("badge_id")
  earnedAt       DateTime     @default(now()) @map("earned_at")
  badge          Badge        @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@unique([childProfileId, badgeId])
  @@map("child_badges")
}

model RewardTransaction {
  id             String       @id @default(cuid())
  childProfileId String       @map("child_profile_id")
  type           RewardType
  amount         Int          @default(0)
  reason         String?
  sourceType     String?      @map("source_type")
  sourceId       String?      @map("source_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@index([childProfileId])
  @@map("reward_transactions")
}

enum AuthProvider {
  email
  google
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ProgressContentType {
  LANGUAGE
  LESSON
  STORY
  GAME
}

enum RewardType {
  STARS
  COINS
  BADGE
}

model Payment {
  id                 String            @id @default(cuid())
  userId             String            @map("user_id")
  subscriptionId     String?           @map("subscription_id")
  amount             Int
  status             String
  razorpayOrderId    String            @map("razorpay_order_id") @unique
  razorpayPaymentId  String?           @map("razorpay_payment_id")
  createdAt          DateTime          @default(now()) @map("created_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@map("payments")
}

model LessonVersion {
  id         String   @id @default(cuid())
  lessonId   String   @map("lesson_id")
  version    Int
  snapshot   Json
  changeNote String?  @map("change_note")
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@unique([lessonId, version])
  @@map("lesson_versions")
}

model ImportAuditLog {
  id           String   @id @default(cuid())
  importType   String   @map("import_type")
  fileName     String?  @map("file_name")
  importedBy   String   @map("imported_by")
  totalRecords Int      @default(0) @map("total_records")
  successCount Int      @default(0) @map("success_count")
  failureCount Int      @default(0) @map("failure_count")
  errors       Json?
  status       String   @default("completed")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([importedBy])
  @@index([createdAt])
  @@map("import_audit_logs")
}

model Media {
  id           String   @id @default(cuid())
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  url          String
  provider     String   @default("local")
  folder       String?
  altText      String?  @map("alt_text")
  uploadedBy   String?  @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([folder])
  @@index([mimeType])
  @@map("media")
}
